{
  "name": "@miolab/openknowledge-monorepo",
  "author": "Lucas Formiga",
  "homepage": "https://github.com/lucasformiga/openknowledge",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check . --fix",
    "pretest": "npm run check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "brace-expansion": ">=2.0.3",
    "path-to-regexp": ">=0.1.13"
  },
  "packageManager": "npm@10.9.0"
}
