{
  "name": "@openknowledge/core",
  "version": "0.0.1",
  "description": "Core routing and LLM logic for OpenKnowledge AI agents.",
  "author": "OpenKnowledge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucasformiga/openknowledge.git"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "knowledge",
    "router",
    "open source",
    "open-source",
    "opensource"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/ai": "^0.5.1",
    "@tanstack/ai-anthropic": "^0.5.0",
    "@tanstack/ai-gemini": "^0.5.0",
    "@tanstack/ai-openai": "^0.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
